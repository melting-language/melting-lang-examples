let arr = [1, 2, "hello"];
let encoded = jsonEncode(arr);
print encoded;

let decoded = jsonDecode(encoded);
print decoded;
print decoded[0];
print decoded[2];

let objStr = "{\"name\":\"Melt\",\"count\":42}";
let obj = jsonDecode(objStr);
print obj;
print obj.name;
print obj.count;

let back = jsonEncode(obj);
print back;
