// Catching interpreter runtime errors (e.g. unknown variable, type errors)
print "--- Catching unknown variable ---";
try {
    let x = noSuchVariable;
} catch (e) {
    print "caught: " + e;
}

print "--- Catching property on non-object ---";
try {
    let n = 42;
    let _ = n.foo;
} catch (e) {
    print "caught: " + e;
}

print "--- Catching array index on non-array ---";
try {
    let s = "hello";
    let _ = s[0];
} catch (e) {
    print "caught: " + e;
}

print "done";
