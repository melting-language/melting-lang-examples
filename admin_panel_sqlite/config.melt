// Admin panel config: app name, port, SQLite DB path.
// Build Melt with SQLite (default with cmake). Run: ./build/melt examples/admin_panel_sqlite/main.melt
// dbPath is relative to the script directory (data.sqlite next to main.melt).

class AppConfig {
    method init() {
        this.name = "Admin Panel";
        this.port = 8080;
        this.dbPath = "data.sqlite";
    }
}

let app = AppConfig();
