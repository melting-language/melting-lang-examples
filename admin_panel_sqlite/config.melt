// Admin panel config: app name, port, SQLite DB path.
// Build Melt with SQLite: make with-sqlite
// Run from project root so dbPath resolves: ./build/melt examples/admin_panel_sqlite/main.melt

class AppConfig {
    method init() {
        this.name = "Admin Panel";
        this.port = 8080;
        this.dbPath = "examples/admin_panel_sqlite/data.sqlite";
    }
}

let app = AppConfig();
