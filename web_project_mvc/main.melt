import "config/app.melt";
import "routes.melt";


class App {
    method handle() {
        let path = getRequestPath();
        Router().dispatch(path);
    }
}

setHandler("App");
print "Melt MVC server: http://localhost:" + app.port;
print "  /  - Home   /items - Items   /about - About";
listen(app.port);
