// Database configuration for MySQL (optional: build with make with-mysql).
// Use: import "config/database.melt" then mysqlConnect(db.host, db.user, db.password, db.database)

class DatabaseConfig {
    method init() {
        this.host = "127.0.0.1";
        this.user = "root";
        this.password = "";
        this.database = "melt_app";
        this.enabled = 0;
    }
}

let db = DatabaseConfig();
